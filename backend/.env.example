# =============================================================================
# Survey Chatbot — Backend Environment Variables
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your actual values below
#   3. NEVER commit the .env file to git (it's in .gitignore)
# =============================================================================

# -------------------------------------------
# REQUIRED: OpenRouter API Key
# Get yours at: https://openrouter.ai/keys
# -------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here

# -------------------------------------------
# OPTIONAL: OpenRouter model and endpoint
# Keep defaults unless you want a different model/provider routing.
# -------------------------------------------
OPENROUTER_MODEL=qwen/qwen3.6-plus-preview:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# -------------------------------------------
# OPTIONAL: Attribution headers (recommended by OpenRouter)
# -------------------------------------------
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Survey Chatbot

# -------------------------------------------
# REQUIRED: Google API Key (replaces credentials.json — no service account needed)
# Steps:
#   1. Go to https://console.cloud.google.com/
#   2. APIs & Services → Enable APIs → enable "Google Sheets API"
#   3. APIs & Services → Credentials → + Create Credentials → API Key
#   4. Copy the key and paste it here
#   5. Make your Google Sheet public: Share → Anyone with the link → Viewer
# -------------------------------------------
GOOGLE_API_KEY=your_google_api_key_here

# -------------------------------------------
# REQUIRED: Google Sheet ID (pre-filled — already your sheet)
# This is the long ID from your sheet URL between /d/ and /edit
# -------------------------------------------
GOOGLE_SHEET_ID=1ABWgQgUzBKHr1Gd9mGUJ4TgeYj-M8KFrE1cP9gjyl4s

# -------------------------------------------
# OPTIONAL: Worksheet tab name (default: "Form Responses 1")
# Check the tab name at the bottom of your Google Sheet
# -------------------------------------------
GOOGLE_SHEET_TAB=Form Responses 1

# -------------------------------------------
# OPTIONAL: Cache TTL in seconds (default: 60)
# How often to refresh data from Google Sheets.
# -------------------------------------------
CACHE_TTL_SECONDS=60
