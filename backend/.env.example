# =============================================================================
# Survey Chatbot — Backend Environment Variables
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your actual values below
#   3. NEVER commit the .env file to git (it's in .gitignore)
# =============================================================================

# -------------------------------------------
# REQUIRED: Gemini API Key
# Get yours for free at: https://aistudio.google.com/app/apikey
# -------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -------------------------------------------
# REQUIRED: Google Sheet Name
# This is the EXACT name of your Google Sheet
# (the title shown at the top of the sheet, e.g. "Form Responses 1")
# NOT the URL — just the plain text name.
# -------------------------------------------
GOOGLE_SHEET_NAME=your_google_sheet_name_here

# -------------------------------------------
# REQUIRED: Path to your Google Service Account credentials JSON
# Download from: Google Cloud Console → IAM & Admin → Service Accounts
#   → your account → Keys → Add Key → JSON
# Place the file in the backend/ folder and set the path here.
# Default is credentials.json (same folder as main.py)
# -------------------------------------------
CREDENTIALS_JSON_PATH=credentials.json

# -------------------------------------------
# OPTIONAL: Cache TTL in seconds (default: 60)
# How often to refresh data from Google Sheets.
# Increase this if you want fewer API calls (e.g., 300 for 5 minutes).
# -------------------------------------------
CACHE_TTL_SECONDS=60
