{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/*.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    }
  ],
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat.py" },
    { "source": "/api/stats", "destination": "/api/stats.py" }
  ]
}
